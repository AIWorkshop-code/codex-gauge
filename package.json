{
  "name": "codex-gauge",
  "version": "0.5.3",
  "description": "A compact Windows and macOS desktop gauge for local Codex quota status.",
  "author": "Codex Gauge",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "build:desktop": "npm run build && electron-builder --win nsis",
    "build:mac": "npm run build && electron-builder --mac --arm64",
    "preview": "vite preview",
    "test": "node --test tests/*.test.cjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "electron-updater": "^6.8.9",
    "react": "19.2.0",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@openai/codex": "^0.144.1",
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "electron-builder": "26.0.12",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.codexgauge.app",
    "productName": "Codex Gauge",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "AIWorkshop-code",
      "repo": "codex-gauge",
      "releaseType": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "Codex-Gauge-Setup-${version}.${ext}",
      "extraResources": [
        {
          "from": "node_modules/@openai/codex-win32-x64/vendor/x86_64-pc-windows-msvc",
          "to": "codex-sidecar",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "artifactName": "Codex-Gauge-${version}-macOS-${arch}.${ext}",
      "identity": null,
      "extraResources": [
        {
          "from": "node_modules/@openai/codex-darwin-arm64/vendor/aarch64-apple-darwin",
          "to": "codex-sidecar",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "node_modules/.pnpm/@openai+codex@0.144.1-darwin-arm64/node_modules/@openai/codex/vendor/aarch64-apple-darwin",
          "to": "codex-sidecar",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
