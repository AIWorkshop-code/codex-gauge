{
  "name": "codex-gauge",
  "version": "0.4.1",
  "description": "A compact Windows desktop gauge for local Codex quota status.",
  "author": "Codex Gauge",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "build:desktop": "npm run build && electron-builder --win nsis",
    "preview": "vite preview",
    "test": "node --test tests/*.test.cjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "react": "19.2.0",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@openai/codex": "^0.144.1",
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "electron-builder": "26.0.12",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.codexgauge.app",
    "productName": "Codex Gauge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/@openai/codex-win32-x64/vendor/x86_64-pc-windows-msvc",
        "to": "codex-sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "Codex-Gauge-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
